# ============================================================
# No BS Workbench — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# --- Database ---
# Postgres connection string (Azure Flexible Server or local)
DATABASE_URL=

# --- NextAuth ---
# Generate a random secret: `openssl rand -base64 32`
AUTH_SECRET=
# Required in production so NextAuth knows the canonical URL
NEXTAUTH_URL=https://finder.no-bshomes.com

# --- Google OAuth (Phase 30.1) ---
# Setup: see docs/google-services.md section 3
# Create credentials in Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Azure Storage ---
# Blob + Queue connection string (from Azure portal → Storage account → Access keys)
AZURE_STORAGE_CONNECTION_STRING=

# --- Azure Document Intelligence ---
# For floor-plan / document parsing (optional if not using that feature)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- Email (Resend) ---
# API key from resend.com — used for password-reset and notification emails
RESEND_API_KEY=

# --- Public URLs (exposed to browser) ---
# Mapbox token for the property map view
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# App URL for generating links in emails
NEXT_PUBLIC_APP_URL=https://finder.no-bshomes.com

# --- Internal / Integration ---
# API key protecting the lead-intake endpoint (/api/leads)
WEBSITE_LEAD_API_KEY=
# API key for the court/NOD intake webhook
COURT_INTAKE_API_KEY=
# Skip-trace / contact enrichment
TRACERFY_API_KEY=
# Brian's email for system notifications
BRIAN_EMAIL=brian@no-bshomes.com
